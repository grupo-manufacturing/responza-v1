VITE_API_URL=http://localhost:4000/api
# Frontend origins for OAuth redirects (comma-separated in production).
# Example: https://www.responza.in,https://responza.in
VITE_APP_URL=http://localhost:5173

# Supabase Realtime (same project as backend; use anon key only)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Admin dashboard — open Vercel Analytics / Speed Insights (paste dashboard URLs)
# Example: https://vercel.com/your-team/your-project/analytics
# VITE_VERCEL_ANALYTICS_URL=
# VITE_VERCEL_SPEED_INSIGHTS_URL=
VITE_VERCEL_ANALYTICS_URL=
VITE_VERCEL_SPEED_INSIGHTS_URL=

# WhatsApp Embedded Signup (Meta)
VITE_META_APP_ID=
VITE_WHATSAPP_EMBEDDED_CONFIG_ID=
VITE_GRAPH_API_VERSION=v25.0

# Instagram OAuth
VITE_INSTAGRAM_APP_ID=
# Recommended production redirect (must match Meta app + backend INSTAGRAM_REDIRECT_URI):
# VITE_INSTAGRAM_REDIRECT_URI=https://www.responza.in/oauth/instagram/callback
# Legacy backend callback (also supported after COOP fix):
# VITE_INSTAGRAM_REDIRECT_URI=https://your-api-host/auth/instagram/callback
VITE_INSTAGRAM_REDIRECT_URI=http://localhost:5173/oauth/instagram/callback

# Gmail OAuth
VITE_GOOGLE_CLIENT_ID=
# Recommended production redirect (must match Google Cloud console + backend GMAIL_REDIRECT_URI):
# VITE_GMAIL_REDIRECT_URI=https://www.responza.in/oauth/gmail/callback
# Legacy backend callback (also supported after COOP fix):
# VITE_GMAIL_REDIRECT_URI=https://your-api-host/auth/gmail/callback
VITE_GMAIL_REDIRECT_URI=http://localhost:5173/oauth/gmail/callback
