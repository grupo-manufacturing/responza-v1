VITE_API_URL=http://localhost:4000/api

# Supabase Realtime + Auth (same project as backend; use anon key only)
# Add redirect URLs in Supabase Auth URL configuration:
# http://localhost:5173/auth/verify-email
# http://localhost:5173/oauth/google/callback
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# WhatsApp Embedded Signup (Meta)
VITE_META_APP_ID=
VITE_WHATSAPP_EMBEDDED_CONFIG_ID=
VITE_GRAPH_API_VERSION=v25.0

# Instagram OAuth
VITE_INSTAGRAM_APP_ID=
VITE_INSTAGRAM_REDIRECT_URI=http://localhost:4000/auth/instagram/callback
