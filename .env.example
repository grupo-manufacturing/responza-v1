# VITE_API_URL=https://your-backend.example.com/api
VITE_API_URL=

# Meta / WhatsApp Embedded Signup (Phase 5)
VITE_META_APP_ID=
VITE_WHATSAPP_EMBEDDED_CONFIG_ID=
VITE_GRAPH_API_VERSION=v25.0
